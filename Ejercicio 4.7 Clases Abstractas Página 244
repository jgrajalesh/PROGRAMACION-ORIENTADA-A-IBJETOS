from abc import ABC, abstractmethod

class Animal(ABC):
    """
    Clase abstracta que modela un animal genérico que cuenta con 
    comportamientos para obtener su sonido, alimentos, hábitat y nombre científico.
    """

    @abstractmethod
    def get_nombre_cientifico(self):
        pass

    @abstractmethod
    def get_sonido(self):
        pass

    @abstractmethod
    def get_alimentos(self):
        pass

    @abstractmethod
    def get_habitat(self):
        pass


class Canido(Animal):
    """
    Clase abstracta denominada Cánido que modela esta familia de animales.
    """
    pass


class Felino(Animal):
    """
    Clase abstracta denominada Felino que modela esta familia de animales.
    """
    pass


class Perro(Canido):
    """
    Clase concreta denominada Perro, subclase de Canido.
    """
    def get_sonido(self):
        return "Ladrido"

    def get_alimentos(self):
        return "Carnívoro"

    def get_habitat(self):
        return "Doméstico"

    def get_nombre_cientifico(self):
        return "Canis lupus familiaris"


class Lobo(Canido):
    """
    Clase concreta denominada Lobo, subclase de Canido.
    """
    def get_sonido(self):
        return "Aullido"

    def get_alimentos(self):
        return "Carnívoro"

    def get_habitat(self):
        return "Bosque"

    def get_nombre_cientifico(self):
        return "Canis lupus"


class Leon(Felino):
    """
    Clase concreta denominada León, subclase de Felino.
    """
    def get_sonido(self):
        return "Rugido"

    def get_alimentos(self):
        return "Carnívoro"

    def get_habitat(self):
        return "Praderas"

    def get_nombre_cientifico(self):
        return "Panthera leo"


class Gato(Felino):
    """
    Clase concreta denominada Gato, subclase de Felino.
    """
    def get_sonido(self):
        return "Maullido"

    def get_alimentos(self):
        return "Ratones"

    def get_habitat(self):
        return "Doméstico"

    def get_nombre_cientifico(self):
        return "Felis silvestris catus"


if __name__ == "__main__":
    # Define una lista dinámica que reemplaza el array estático de Java
    animales = [Gato(), Perro(), Lobo(), Leon()]

    # Recorre la lista de animales ejecutando métodos polimórficos
    for animal in animales:
        print(animal.get_nombre_cientifico())
        print(f"Sonido: {animal.get_sonido()}")
        print(f"Alimentos: {animal.get_alimentos()}")
        print(f"Hábitat: {animal.get_habitat()}\n")
