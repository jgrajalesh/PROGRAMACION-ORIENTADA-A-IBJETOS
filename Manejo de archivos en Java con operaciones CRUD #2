import os
import subprocess

class DisplayFriends:
    @staticmethod
    def main():
        # Ruta del archivo especificada
        file_path = r"C:\Users\esteb\OneDrive\Escaneos\Documentos\POO\friendsContact.txt"
        
        # Extraer el directorio de la ruta y crearlo si no existe
        directory = os.path.dirname(file_path)
        if directory and not os.path.exists(directory):
            os.makedirs(directory, exist_ok=True)

        # Sobrescribir el archivo con los contactos exactos de la imagen
        try:
            with open(file_path, 'w', encoding='utf-8') as f:
                f.write("abc!1234567890\n")
                f.write("lmn!3333333333\n")
                f.write("xyz!4444444444\n")
            
            # Lanzar el proceso de Notepad con el archivo creado
            subprocess.Popen(['notepad.exe', file_path])
            
        except IOError as ioe:
            print(f"Error de entrada/salida: {ioe}")
        except FileNotFoundError:
            print("Error: No se pudo encontrar el ejecutable de Notepad en el sistema.")

if __name__ == "__main__":
    DisplayFriends.main()
