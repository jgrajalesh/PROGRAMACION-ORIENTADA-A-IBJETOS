import sys
import os
import asyncio
import tkinter as tk
import random
import string

FILENAME = "friendsContact.txt"

async def add_friend(new_name: str, new_number: int):
    if not os.path.exists(FILENAME):
        with open(FILENAME, "w") as f:
            pass
    
    try:
        with open(FILENAME, "r+") as f:
            lines = f.readlines()
            found = False
            for line in lines:
                if line.strip() and "!" in line:
                    parts = line.strip().split("!")
                    if parts[0] == new_name or int(parts[1]) == new_number:
                        found = True
                        break
            
            if not found:
                f.seek(0, 2)
                f.write(f"{new_name}!{new_number}{os.linesep}")
                print(f"Registro guardado: {new_name}!{new_number}")
            else:
                print("El registro ya existe.")
    except IOError as e:
        print(f"Error: {e}")

async def generate_random_friends(target_count: int = 4):
    for _ in range(target_count):
        random_name = ''.join(random.choices(string.ascii_lowercase, k=3))
        random_number = random.randint(1000000000, 9999999999)
        await add_friend(random_name, random_number)

class NotepadInterface:
    def __init__(self, root: tk.Tk, filename: str):
        self.root = root
        self.filename = filename
        
        self.root.title(f"{self.filename} - Notepad")
        self.root.geometry("600x300")
        
        self._setup_menu()
        self._setup_text_area()
        self.load_content()

    def _setup_menu(self):
        menubar = tk.Menu(self.root)
        self.root.config(menu=menubar)
        
        menus = ["File", "Edit", "Format", "View", "Help"]
        for item in menus:
            menu_cascade = tk.Menu(menubar, tearoff=0)
            menubar.add_cascade(label=item, menu=menu_cascade)

    def _setup_text_area(self):
        self.text_area = tk.Text(
            self.root, 
            font=("Times New Roman", 24), 
            undo=True, 
            wrap="word",
            borderwidth=0,
            highlightthickness=0
        )
        self.text_area.pack(expand=True, fill="both")

    def load_content(self):
        if os.path.exists(self.filename):
            with open(self.filename, "r") as f:
                content = f.read()
                self.text_area.insert(tk.END, content)

def launch_gui():
    root = tk.Tk()
    app = NotepadInterface(root, FILENAME)
    root.mainloop()

if __name__ == "__main__":
    if not os.path.exists(FILENAME) or os.path.getsize(FILENAME) == 0:
        asyncio.run(generate_random_friends(4))
        
    if len(sys.argv) > 1:
        if sys.argv[1] == "--random":
            asyncio.run(generate_random_friends(4))
        elif len(sys.argv) > 2:
            try:
                name = sys.argv[1]
                number = int(sys.argv[2])
                asyncio.run(add_friend(name, number))
            except (IndexError, ValueError) as e:
                print(e)
                sys.exit(1)
    else:
        launch_gui()
